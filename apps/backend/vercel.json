{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts",
      "methods": ["GET", "POST", "PATCH", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
