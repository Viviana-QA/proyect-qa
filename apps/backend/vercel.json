{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/generate-stream.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/explore-stream.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate-stream",
      "dest": "api/generate-stream.js"
    },
    {
      "src": "/api/explore-stream",
      "dest": "api/explore-stream.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
