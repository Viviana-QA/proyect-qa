{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx nest build",
  "functions": {
    "api/index.js": {
      "maxDuration": 10,
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
